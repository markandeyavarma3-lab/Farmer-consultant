# Copy this file to .env (local dev) or paste values into Streamlit Cloud Secrets.
# Both APIs are free — no credit card needed.

# Groq — free at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Sarvam AI — free signup at https://dashboard.sarvam.ai
# Needed only for Telugu/Hindi voice. App still works (text + gTTS) without it.
SARVAM_API_KEY=your_sarvam_api_key_here
